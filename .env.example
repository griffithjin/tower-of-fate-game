PORT=3000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/fate_tower
MONGODB_URI_PROD=mongodb+srv://<username>:<password>@cluster.mongodb.net/fate_tower?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRE=30d

# Payment Configuration - Alipay
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key-content
ALIPAY_PRIVATE_KEY_PATH=/path/to/alipay/private-key.pem
ALIPAY_PUBLIC_KEY=your-alipay-public-key-content
ALIPAY_PUBLIC_KEY_PATH=/path/to/alipay/public-key.pem
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# Payment Configuration - WeChat Pay
WECHAT_APP_ID=your-wechat-app-id
WECHAT_MCH_ID=your-wechat-merchant-id
WECHAT_API_KEY=your-wechat-api-key
WECHAT_PFX_PATH=/path/to/wechat/apiclient_cert.p12
WECHAT_NOTIFY_URL=https://your-domain.com/api/payment/wechat-callback

# API Configuration
API_BASE_URL=https://your-domain.com
CLIENT_URL=https://your-game-client.com
SERVER_IP=your-server-ip

# Game Configuration
GAME_MAX_PLAYERS=2
GAME_TURN_TIMEOUT=30000
MATCHMAKING_TIMEOUT=60000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:8080,https://your-domain.com
